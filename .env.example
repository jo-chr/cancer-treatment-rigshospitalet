# Copy to .env and fill in. .env is gitignored.

# --- LLM provider ---
# Default: OpenAI. Swap for Azure OpenAI in production (EU residency for GDPR).
OPENAI_API_KEY=sk-...

# Models
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Paths ---
DOCS_DIR=hospital_documents
CHROMA_DIR=.chroma

# --- Retrieval ---
TOP_K=5
MIN_SIMILARITY=0.25

# --- Behavior ---
# Documents older than this many days get a freshness warning in the answer.
STALE_DAYS=730
